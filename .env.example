# ──────────────────────────────────────────────────────────────────────────────
# MarketFlux — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/marketflux?sslmode=require"

# ── Auth (Better Auth) ────────────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with: openssl rand -hex 32"
BETTER_AUTH_URL="http://localhost:3001"

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Redis / BullMQ (Upstash) ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Meilisearch ───────────────────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_ADMIN_API_KEY="masterKey"

# ── Storage (Cloudflare R2) ────────────────────────────────────────────────
S3_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="marketflux-uploads"

# ── Monitoring ──────────────────────────────────────────────────────────────
SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"
NEXT_PUBLIC_SENTRY_DSN="https://xxx@oXXX.ingest.sentry.io/XXX"

# ── Frontend public vars ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── CI / Deploy secrets (configurar en GitHub Actions Secrets) ────────────────
# FLY_API_TOKEN
# VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID
