{
  "title": "MarketFlux API Overview",
  "uid": "marketflux-api-overview",
  "schemaVersion": 38,
  "tags": ["marketflux", "api"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [{
        "expr": "sum(rate(http_requests_total[1m])) by (route)",
        "legendFormat": "{{route}}"
      }]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
        "legendFormat": "Error Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "p95 Latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
        "legendFormat": "p95 {{route}}"
      }]
    },
    {
      "id": 4,
      "title": "Active Users",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "active_users_gauge",
        "legendFormat": "Active Users"
      }]
    },
    {
      "id": 5,
      "title": "Orders Created (rate)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "sum(rate(orders_created_total[5m])) by (status)",
        "legendFormat": "{{status}}"
      }]
    },
    {
      "id": 6,
      "title": "BullMQ Queue Depth",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [{
        "expr": "bullmq_queue_depth",
        "legendFormat": "{{queue}}"
      }]
    }
  ]
}
